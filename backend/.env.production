# ============================================================================
# PRODUCTION ENVIRONMENT VARIABLES
# ============================================================================
# Copy this file to .env and fill in the values
# KEEP THIS FILE SECURE - DO NOT COMMIT TO GIT

# ---- DATABASE ----
# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/reel_rag_prod

# ---- JWT SECURITY ----
# Generate a strong secret key:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-super-secret-key-generate-with-command-above

# ---- CORS ----
# Comma-separated list of allowed origins (no spaces)
# Example: https://app.com,https://www.app.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ---- STORAGE ----
# Local file storage path for video uploads
STORAGE_LOCAL_PATH=./data/uploads

# ---- ASR (Speech-to-Text) ----
# Options: "stub" (default) or "openai"
# stub: Returns fake transcript (free, for MVP)
# openai: Uses Whisper API (requires OPENAI_API_KEY)
ASR_MODE=stub

# ---- EMBEDDINGS ----
# Options: "stub" (default) or "openai"
# stub: Returns fake embeddings (free, for MVP)
# openai: Uses OpenAI embeddings API (requires OPENAI_API_KEY)
EMBED_MODE=stub

# Embedding dimension (must match model)
# Default 1536 for OpenAI text-embedding-3-small
EMBED_DIM=1536

# ---- OPENAI API KEY ----
# Required if ASR_MODE or EMBED_MODE is "openai"
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-api-key-here

# ---- LOGGING ----
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ---- ENVIRONMENT ----
# For error messages and monitoring
ENVIRONMENT=production
