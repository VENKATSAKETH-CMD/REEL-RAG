# ============================================================================
# Reel RAG Backend Configuration
# ============================================================================
# Copy this file to .env and set the values for your environment.
# See README.md for setup instructions.
# ============================================================================

# DATABASE: PostgreSQL with pgvector extension (REQUIRED)
# Format: postgresql://user:password@host:port/database
# Example: postgresql://postgres:password@localhost:5432/reel_rag_dev
DATABASE_URL=postgresql://postgres:password@localhost:5432/reel_rag_dev

# AUTHENTICATION
# A random string used to sign JWT tokens. Use a strong random value in production.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=dev-secret-key-change-in-production

# JWT algorithm for token signing (usually HS256)
ALGORITHM=HS256

# How long JWT tokens are valid (in minutes). Default: 60
ACCESS_TOKEN_EXPIRE_MINUTES=60

# FILE STORAGE
# Local directory to store uploaded video files (relative to backend root)
STORAGE_LOCAL_PATH=./data/uploads

# EMBEDDINGS
# Dimension of embedding vectors (used by pgvector column type)
# Must match the model's output dimension. Default: 1536 (OpenAI text-embedding-3-small)
EMBED_DIM=1536

# Embedding mode:
# - "stub": Deterministic stub embeddings (no API calls, good for development)
# - Future: "openai" (not implemented yet; requires OPENAI_API_KEY)
EMBED_MODE=stub

# SPEECH-TO-TEXT (ASR)
# ASR mode:
# - "stub": Dummy transcription (no API calls, good for development)
# - Future: "openai" (uses OpenAI Whisper, requires OPENAI_API_KEY)
ASR_MODE=stub

# OPENAI API (OPTIONAL)
# Required if using EMBED_MODE=openai or ASR_MODE=openai
# Get your API key from: https://platform.openai.com/api-keys
# Leave empty if using stub mode (default)
OPENAI_API_KEY=

# OpenAI model for chat completions (used in RAG answer generation)
# Default: gpt-4o-mini (recommended for cost-effectiveness)
OPENAI_MODEL=gpt-4o-mini

# ============================================================================
# PRODUCTION NOTES
# ============================================================================
# - Always change SECRET_KEY to a secure random value
# - Use a managed PostgreSQL service with pgvector enabled (e.g., AWS RDS with pgvector)
# - Enable SSL/TLS for database connections in production
# - Use environment-specific secrets management (AWS Secrets Manager, HashiCorp Vault, etc.)
# - Set OPENAI_API_KEY securely if using OpenAI models
